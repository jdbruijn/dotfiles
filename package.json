{
  "name": "dotfiles",
  "version": "3.1.1",
  "private": true,
  "description": "dotfiles, software and macOS defaults",
  "homepage": "https://github.com/jdbruijn/dotfiles#readme",
  "bugs": {
    "url": "https://github.com/jdbruijn/dotfiles/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdbruijn/dotfiles.git"
  },
  "license": "GPL-3.0-or-later",
  "author": "Jeroen de Bruijn",
  "type": "module",
  "scripts": {
    "build": "",
    "format": "prettier --write \"**/*.{vue,css,less,scss,html,htm,json,md,markdown,yml,yaml}\" --log-level warn",
    "format:check": "prettier --check \"**/*.{vue,css,less,scss,html,htm,json,md,markdown,yml,yaml}\" --log-level warn",
    "lint": "npm run format:check",
    "lint:fix": "npm run format",
    "prepare": "husky .github/husky",
    "test": ""
  },
  "commitlint": {
    "extends": [
      "@vidavidorra"
    ]
  },
  "prettier": {
    "singleQuote": true
  },
  "release": {
    "extends": "@vidavidorra/semantic-release-config"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.0",
    "@vidavidorra/commitlint-config": "7.1.19",
    "@vidavidorra/semantic-release-config": "2.0.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.2",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3"
  }
}
